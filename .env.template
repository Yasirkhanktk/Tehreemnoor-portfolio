# ─── DATABASE ─────────────────────────────────────────────────────────────────
# MongoDB connection string (Free Atlas tier or local database)
DATABASE_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/portfolio?retryWrites=true&w=majority
# Local fallback: mongodb://127.0.0.1:27017/portfolio

# ─── PAYLOAD CMS ──────────────────────────────────────────────────────────────
# Random string for encrypting cookies and session keys
PAYLOAD_SECRET=generate-a-long-secure-random-string-here

# ─── CLOUD STORAGE FALLBACKS (CHOOSE ONE OR LEAVE BLANK FOR LOCAL DISK) ───────

# OPTION A: Supabase Storage (S3-Compatible)
# S3_BUCKET=your-supabase-bucket-name
# S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
# S3_ACCESS_KEY_ID=your-s3-access-key-id
# S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
# S3_REGION=us-east-1

# OPTION B: Firebase Storage (Google Cloud Storage)
# GCS_BUCKET=your-firebase-project.appspot.com
# GCS_PROJECT_ID=your-firebase-project-id
# GCS_CLIENT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com
# GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
